# Bu dosyayı `.env` olarak kopyala ve PostgreSQL şifreni değiştir.
# .env dosyasını repoya ekleme (.gitignore'da tutuluyor).

# --- Veritabanı -----------------------------------------------------------
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5433/postgres

# --- Uygulama -------------------------------------------------------------
APP_NAME=Synapse Backend
APP_ENV=dev
LOG_LEVEL=INFO

# Virgülle ayrılmış kesin CORS origin listesi. Boşsa
# `https?://(localhost|127.0.0.1)(:port)?` regex'i uygulanır.
# Örn: CORS_ORIGINS=https://app.synapse.local,http://localhost:3000
CORS_ORIGINS=

# --- Sequence miner / decision engine ------------------------------------
SEQUENCE_DECAY_LAMBDA=0.0077
SUNRISE_HOUR=6
SUNSET_HOUR=19
PRE_SUNSET_LIGHT_PENALTY=0.65

# --- Recommendation yaşam döngüsü ----------------------------------------
RECOMMENDATION_MAX_AGE_MINUTES=5

# --- Habit matrix scheduler ----------------------------------------------
HABIT_MATRIX_REBUILD_HOUR=3

# --- Auth / JWT ----------------------------------------------------------
# Production ortamında MUTLAKA güçlü rastgele bir değer ile değiştir:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=CHANGE_ME_DEV_SECRET_DO_NOT_USE_IN_PROD
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Docker compose ------------------------------------------------------
# `docker compose up` icin (varsayilanlar yetiyorsa bunlari atla):
# POSTGRES_PASSWORD=postgres
# POSTGRES_HOST_PORT=5433
# API_HOST_PORT=8000
